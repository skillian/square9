	"version": "0.2.0",
	"configurations": [
		{
			"name": "Brooks",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${workspaceFolder}/gscp/gscp",
			"args": [
				"--delete",
				"--from-index",
				"--to-index",
				"--append-index",
				"--local-output-filename-format", "Brooks {0}",
				"--disable-raw-terminal",
				"--max-errors", "-1",
				"--log-console", "info",
				"C:\\Users\\Sean\\Downloads\\Brooks\\source.csv",
				"C:\\Users\\Sean\\Downloads\\Brooks\\dest.csv"
			],
			"console": "integratedTerminal"
		},
		{
			"name": "LancoROW",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${workspaceFolder}/gscp/gscp",
			"args": [
				"--from-index",
				"--to-index",
				"--append-index",
				"--local-output-filename-format", "ROW_OC_Probate - {1} - {0}",
				"--disable-raw-terminal",
				"--max-errors", "-1",
				"--web-session-pool-limit", "8",
				"--log-console", "warn",
				"\\\\square9qa.paperlessus.local\\e$\\square9\\LancoROW\\ROW_OC_Probate_w_specs.csv",
				"\\\\square9qa.paperlessus.local\\e$\\square9\\LancoROW\\ROW_OC_Probate_Exported.csv"
			],
			"console": "integratedTerminal"
		}
	]
